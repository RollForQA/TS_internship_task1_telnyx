{
  "name": "ts-internship",
  "version": "1.0.0",
  "description": "Telnyx site testing — Cypress E2E test suite",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:open:custom": "cypress open --config-file cypress.config.custom.js",
    "cy:run": "cypress run",
    "cy:run:custom": "cypress run --config-file cypress.config.custom.js",
    "cy:run:ci": "cypress run --config-file cypress.config.custom.js --browser chrome",
    "cy:run:smoke": "cypress run --config-file cypress.config.custom.js --env grepTags=@smoke",
    "cy:run:regression": "cypress run --config-file cypress.config.custom.js --env grepTags=@regression",
    "report:merge": "npx mochawesome-merge cypress/reports/*.json -o cypress/reports/merged.json",
    "report:generate": "npx marge cypress/reports/merged.json -f report -o cypress/reports/html",
    "report": "npm run report:merge && npm run report:generate",
    "test": "cypress run --config-file cypress.config.custom.js"
  },
  "keywords": ["cypress", "telnyx", "e2e", "testing"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cypress/grep": "^4.3.0",
    "cypress": "^15.14.0",
    "exceljs": "^4.4.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
